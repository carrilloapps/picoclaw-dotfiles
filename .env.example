# =============================================================================
# PicoClaw Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file — it is excluded via .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Ollama Cloud API
# ---------------------------------------------------------------------------
OLLAMA_API_KEY=<YOUR_OLLAMA_API_KEY>
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=<YOUR_OLLAMA_MODEL>

# ---------------------------------------------------------------------------
# Model Configuration
# ---------------------------------------------------------------------------
DEFAULT_MODEL_NAME=<YOUR_DEFAULT_MODEL_ALIAS>
DEFAULT_MODEL_ID=<PROVIDER_PREFIX/MODEL_ID>
FALLBACK_MODEL_NAME=<YOUR_FALLBACK_MODEL_ALIAS>
FALLBACK_MODEL_ID=<PROVIDER_PREFIX/MODEL_ID>
VOICE_MODEL=<YOUR_VOICE_TRANSCRIPTION_MODEL>

# ---------------------------------------------------------------------------
# Device Hardware (used in documentation and device-context.sh)
# ---------------------------------------------------------------------------
DEVICE_BRAND=<BRAND>
DEVICE_MODEL_NUMBER=<MODEL_NUMBER>
DEVICE_CODENAME=<CODENAME>
DEVICE_SOC=<SOC_MODEL>

# ---------------------------------------------------------------------------
# Termux / Device SSH
# ---------------------------------------------------------------------------
DEVICE_SSH_HOST=<YOUR_DEVICE_IP>
DEVICE_SSH_PORT=<YOUR_SSH_PORT>
DEVICE_SSH_USER=<YOUR_SSH_USER>
DEVICE_SSH_PASSWORD=<YOUR_SSH_PASSWORD>

# ---------------------------------------------------------------------------
# Telegram Bot (optional — for Telegram channel integration)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_BOT_USERNAME=<YOUR_BOT_USERNAME>
TELEGRAM_OWNER_ID=<YOUR_TELEGRAM_USER_ID>

# ---------------------------------------------------------------------------
# Azure OpenAI (optional — enterprise deployment)
# ---------------------------------------------------------------------------
AZURE_OPENAI_BASE_URL=<YOUR_AZURE_RESOURCE_URL>
AZURE_OPENAI_API_KEY=<YOUR_AZURE_API_KEY>
AZURE_OPENAI_DEPLOYMENT=<YOUR_LLM_DEPLOYMENT_NAME>
AZURE_OPENAI_API_VERSION=<API_VERSION>
AZURE_WHISPER_DEPLOYMENT=<YOUR_WHISPER_DEPLOYMENT_NAME>

# ---------------------------------------------------------------------------
# Google AI Studio (optional — Gemini models via API key)
# ---------------------------------------------------------------------------
# Get a free key at: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=<YOUR_GOOGLE_AI_STUDIO_KEY>
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Groq API (optional — for voice message transcription)
# ---------------------------------------------------------------------------
GROQ_API_KEY=<YOUR_GROQ_API_KEY>

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (optional — zero-trust webhook exposure)
# ---------------------------------------------------------------------------
# Get from Cloudflare dashboard > Zero Trust > Networks > Tunnels > create tunnel.
# The token looks like: eyJhIjoi...base64url-encoded JSON.
CLOUDFLARE_TUNNEL_TOKEN=<YOUR_CLOUDFLARE_TUNNEL_TOKEN>

# Tunnel metadata (optional — just for reference / some scripts)
CLOUDFLARE_TUNNEL_NAME=<YOUR_TUNNEL_NAME>
CLOUDFLARE_TUNNEL_DOMAIN=<YOUR_ZONE_DOMAIN>

# Public URL the tunnel exposes (after you configure Public Hostname in CF dashboard).
# Used by the agent via ~/bin/cloudflare-tool.sh url to share webhook endpoints.
WEBHOOK_PUBLIC_URL=<YOUR_PUBLIC_WEBHOOK_URL>

# ---------------------------------------------------------------------------
# Webhook security (auto-generated by install.sh if empty)
# ---------------------------------------------------------------------------
# Bearer token required for /notify and /hook/* endpoints.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_TOKEN=<LEAVE_EMPTY_TO_AUTOGEN>

# HMAC-SHA256 shared secret for generic hook signature verification.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_HMAC_SECRET=<LEAVE_EMPTY_TO_AUTOGEN>

# Separate HMAC secret for GitHub webhooks (X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET=<LEAVE_EMPTY_TO_AUTOGEN>

# Optional: GitLab token (set in GitLab webhook UI under "Secret token")
GITLAB_WEBHOOK_TOKEN=<YOUR_GITLAB_TOKEN>

# Optional: restrict webhook to specific IPs (comma-separated, applies to /notify + /hook/*)
# WEBHOOK_IP_ALLOW=1.2.3.4,5.6.7.8

# Rate limit (requests per minute per IP). Default 60 if unset.
RATE_LIMIT_PER_MIN=120

# Optional: Cloudflare Access JWT verification (Zero Trust Application)
# CF_ACCESS_AUD=your_app_aud_tag
# CF_ACCESS_TEAM=your_team

# ---------------------------------------------------------------------------
# Device PIN (for automatic screen unlock)
# ---------------------------------------------------------------------------
DEVICE_PIN=<YOUR_DEVICE_PIN>

# ---------------------------------------------------------------------------
# System
# ---------------------------------------------------------------------------
SSL_CERT_FILE=/data/data/com.termux/files/usr/etc/tls/cert.pem
